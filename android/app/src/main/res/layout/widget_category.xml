<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <ImageView
            android:layout_width="4dp"
            android:layout_height="16dp"
            android:background="@drawable/widget_accent_bar"
            android:layout_marginEnd="10dp"/>
        <TextView
            android:id="@+id/header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kategori"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>
        <TextView
            android:id="@+id/header_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6612A8FF"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- Item 1 -->
    <LinearLayout
        android:id="@+id/item_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView android:layout_width="4dp" android:layout_height="4dp"
            android:background="#4412A8FF" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/title_1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#E5FFFFFF" android:textSize="11sp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/time_1" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#5512A8FF"
            android:textSize="9sp" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ImageView android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#1AFFFFFF" android:layout_marginVertical="2dp"/>

    <!-- Item 2 -->
    <LinearLayout
        android:id="@+id/item_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView android:layout_width="4dp" android:layout_height="4dp"
            android:background="#4412A8FF" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/title_2" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#E5FFFFFF" android:textSize="11sp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/time_2" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#5512A8FF"
            android:textSize="9sp" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ImageView android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#1AFFFFFF" android:layout_marginVertical="2dp"/>

    <!-- Item 3 -->
    <LinearLayout
        android:id="@+id/item_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView android:layout_width="4dp" android:layout_height="4dp"
            android:background="#4412A8FF" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/title_3" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#E5FFFFFF" android:textSize="11sp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/time_3" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#5512A8FF"
            android:textSize="9sp" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ImageView android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#1AFFFFFF" android:layout_marginVertical="2dp"/>

    <!-- Item 4 -->
    <LinearLayout
        android:id="@+id/item_4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView android:layout_width="4dp" android:layout_height="4dp"
            android:background="#4412A8FF" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/title_4" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#E5FFFFFF" android:textSize="11sp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/time_4" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#5512A8FF"
            android:textSize="9sp" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ImageView android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#1AFFFFFF" android:layout_marginVertical="2dp"/>

    <!-- Item 5 -->
    <LinearLayout
        android:id="@+id/item_5"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView android:layout_width="4dp" android:layout_height="4dp"
            android:background="#4412A8FF" android:layout_marginEnd="8dp"/>
        <TextView android:id="@+id/title_5" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="#E5FFFFFF" android:textSize="11sp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/time_5" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#5512A8FF"
            android:textSize="9sp" android:layout_marginStart="4dp"/>
    </LinearLayout>

</LinearLayout>
